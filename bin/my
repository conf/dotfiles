#!/bin/bash

set -euo pipefail

TEMP_FILE="$(mktemp)"
# clean up temp file on  0: exit shell, 2: Interrupt, 3: Quit, 15: Terminate.
trap "rm -f $TEMP_FILE" 0 2 3 15

VAULT=yulffsqarwkdzimpnukrbfg27m

ITEM_TITLE="$(op item list --vault="$VAULT" --categories=database --format=json |
  jq -r '.[] | "\(.title)" ' |
  gum filter --placeholder "Select database...")"

# Show database name in mycli prompt in red
MYCLI_PROMPT="\x1b[37;41m $ITEM_TITLE \x1b[0m \h> "

ITEM="$(
  op item get "$ITEM_TITLE" --vault="$VAULT" --format=json --fields=username,password,hostname,database |
    jq -r 'map({key: .id, value: .value}) | from_entries'
)"

echo """
[client]
user=$(echo "$ITEM" | jq -r '.username')
password=$(echo "$ITEM" | jq -r '.password')
host=$(echo "$ITEM" | jq -r '.hostname')
database=$(echo "$ITEM" | jq -r '.database')
""" >"$TEMP_FILE"

bash -c "sleep 1; rm -f $TEMP_FILE" &

mycli -R "$MYCLI_PROMPT" --defaults-file "$TEMP_FILE"
